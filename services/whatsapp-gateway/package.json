{
  "name": "vidyaos-whatsapp-gateway",
  "version": "1.0.0",
  "description": "High-load WhatsApp gateway microservice for VidyaOS — handles webhook ingestion, payload normalization, and queue-based forwarding to the Python backend.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "bullmq": "^5.12.0",
    "axios": "^1.7.7",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.4.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.js"]
  }
}
