# VidyaOS Backend Environment Configuration

# Application Settings
APP_ENV=local
DEMO_MODE=true

# Database (SQLite for Demo or PostgreSQL for Production)
DATABASE_URL=sqlite:///./vidyaos_demo.db

# LLM & Vector Store Settings
# To use NVIDIA NIM models (llama-3.1-70b-instruct and nv-embedqa-e5-v5):
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=nvapi-your-llm-api-key-here
EMBEDDING_API_KEY=nvapi-your-embedding-api-key-here

# Authentication (JWT Secret)
SECRET_KEY=demo_secret_key_change_in_production
ALGORITHM=HS256

# CORS Origin (comma separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
