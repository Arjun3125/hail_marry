# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:change-me-local-postgres-password@localhost:5432/vidyaos
POSTGRES_PASSWORD=change-me-local-postgres-password

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Authentication ────────────────────────────
JWT_SECRET=change-me-generate-256-bit-secret
REFRESH_SECRET_KEY=change-me-generate-separate-256-bit-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── AI Service ────────────────────────────────
OLLAMA_URL=http://localhost:11434
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_URLS=http://localhost:8001
AI_SERVICE_KEY=your-internal-api-key

# —— Vector Backend —————————————————————————————
VECTOR_BACKEND_PROVIDER=faiss
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Extended Connectors ───────────────────────────────────────────────────────
# Optional tokens for Google Docs (private docs) and Notion ingestion.
GOOGLE_DOCS_ACCESS_TOKEN=
NOTION_API_KEY=

# ── Application ───────────────────────────────
APP_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Rate Limiting ─────────────────────────────
AI_QUERIES_PER_DAY=50
BURST_LIMIT_PER_MINUTE=5

# ————— Document Watcher ————————————————————————————————————————————————
# Enable automatic ingestion from watched folders.
DOC_WATCH_ENABLED=false
DOC_WATCH_DIRS=
DOC_WATCH_INTERVAL=30
DOC_WATCH_TENANT_ID=
DOC_WATCH_UPLOADER_ID=

# ————— Email (SMTP) ————————————————————————————————————————————————
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@vidyaos.local
SMTP_FROM_NAME=VidyaOS

# ————— Weekly Digest Scheduler ————————————————————————————————————————
DIGEST_EMAIL_ENABLED=false
DIGEST_EMAIL_INTERVAL_MINUTES=10080

# —— Observability Alerts ——————————————————————————
OBSERVABILITY_ALERT_EMAILS=
OBSERVABILITY_ALERT_SMS=

# —— Sentry (Error Tracking) ————————————————
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_PII=false

# —— SMS Provider (Twilio) ——————————————————
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=

# —— PostHog (Product Analytics) ——————————————
POSTHOG_API_KEY=phc_your_backend_api_key
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_your_frontend_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
